---
import { render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getEntryEditHref, getPublicEntrySlug, getPublishedEntries, type PublishedEntry } from "@/lib/content";

export async function getStaticPaths() {
  const entries = await getPublishedEntries();

  return entries.map((entry) => ({
    params: { slug: getPublicEntrySlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: PublishedEntry };
const { Content } = await render(entry);
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  dateStyle: "long",
}).format(entry.data.pubDate);
const demoUrl = "demoUrl" in entry.data ? entry.data.demoUrl : undefined;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="article">
    <p class="meta">{formattedDate}</p>
    <h1>{entry.data.title}</h1>
    <p class="lede">{entry.data.description}</p>
    <p class="edit-link">
      <a href={getEntryEditHref(entry)}>编辑此页</a>
    </p>
    <ul class="tag-list" aria-label="Tags">
      {entry.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    {
      demoUrl && (
        <p>
          <a href={demoUrl}>打开关联演示</a>
        </p>
      )
    }
    <Content />
  </article>
</BaseLayout>

<style>
  .edit-link {
    margin: 1rem 0;
  }

  .edit-link a {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--accent-soft);
    display: inline-flex;
    font-weight: 800;
    padding: 0.45rem 0.85rem;
    text-decoration: none;
  }
</style>
