---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentCard from "@/components/ContentCard.astro";

const demos = (await getCollection("demos", ({ data }) => data.status === "published")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Demo" description="Hybrid Blog 的 demo 和工具集合。">
  <section class="hero">
    <p class="eyebrow">Demos</p>
    <h1>Demo</h1>
    <p class="lede">用于展示原型、视频脚本、交互组件和工具页。</p>
  </section>

  <ul class="content-list">
    {
      demos.map((demo) => (
        <li>
          <ContentCard
            href={`/demos/${demo.id}/`}
            title={demo.data.title}
            description={demo.data.description}
            pubDate={demo.data.pubDate}
            tags={demo.data.tags}
          />
        </li>
      ))
    }
  </ul>
</BaseLayout>
