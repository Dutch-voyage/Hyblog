---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const demos = await getCollection("demos", ({ data }) => data.status === "published");
  return demos.map((demo) => ({
    params: { slug: demo.id },
    props: { demo },
  }));
}

const { demo } = Astro.props;
const { Content } = await render(demo);
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  dateStyle: "long",
}).format(demo.data.pubDate);
---

<BaseLayout title={demo.data.title} description={demo.data.description}>
  <article class="article">
    <p class="meta">{formattedDate}</p>
    <h1>{demo.data.title}</h1>
    <p class="lede">{demo.data.description}</p>
    <ul class="tag-list" aria-label="Tags">
      {demo.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
    {
      demo.data.demoUrl && (
        <p>
          <a href={demo.data.demoUrl}>打开 demo</a>
        </p>
      )
    }
    <Content />
  </article>
</BaseLayout>
