---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A minimal personal blog for hybrid writing experiments.",
} = Astro.props;

const siteTitle = "Hybrid Blog";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Hybrid Blog</a>
      <nav aria-label="Main navigation">
        <a href="/posts/">文章</a>
        <a href="/notes/">笔记</a>
        <a href="/demos/">Demo</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Built with Astro, MDX, and Git-based content.</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --background: #fbfaf8;
    --surface: #ffffff;
    --text: #1d1b18;
    --muted: #6f6a63;
    --border: #e8e1d8;
    --accent: #8a4f2c;
    --accent-soft: #f4e4d8;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --background: #151311;
      --surface: #201d19;
      --text: #f3eee7;
      --muted: #b7afa5;
      --border: #38322d;
      --accent: #e7a66e;
      --accent-soft: #2d241d;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--background);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, var(--accent), transparent 35%);
    text-underline-offset: 0.2em;
  }

  a:hover {
    color: var(--accent);
  }

  main,
  .site-header,
  .site-footer {
    width: min(100% - 2rem, 920px);
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
  }

  .brand {
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    color: var(--muted);
    margin-top: 4rem;
    padding: 1.5rem 0 2rem;
    font-size: 0.9rem;
  }

  h1,
  h2,
  h3 {
    line-height: 1.2;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    letter-spacing: -0.05em;
  }

  h2 {
    margin-top: 2.5rem;
  }

  p {
    color: color-mix(in srgb, var(--text), var(--muted) 22%);
  }

  code {
    border-radius: 0.35rem;
    background: var(--accent-soft);
    padding: 0.1rem 0.3rem;
    font-size: 0.92em;
  }

  pre {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
  }

  .hero {
    padding: 4rem 0 3rem;
  }

  .eyebrow {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lede {
    max-width: 680px;
    color: var(--muted);
    font-size: 1.2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
    padding: 1.25rem;
  }

  .card h2,
  .card h3 {
    margin-top: 0;
  }

  .meta {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    padding: 0.15rem 0.6rem;
    font-size: 0.85rem;
  }

  .content-list {
    display: grid;
    gap: 1rem;
    padding: 0;
    list-style: none;
  }

  .article {
    max-width: 720px;
    padding-top: 2rem;
  }
</style>
